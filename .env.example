# ===== BANCO DE DADOS (OBRIGATÓRIO) =====
# Formato: postgresql://user:password@host:port/dbname
# Exemplo local: postgresql://postgres:postgres@localhost:5432/machado_assis
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ===== DJANGO (OBRIGATÓRIO EM PRODUÇÃO) =====
# Chave secreta para criptografia (gerar: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DJANGO_SECRET_KEY=your-super-secret-key-change-in-production

# Debug mode (true para desenvolvimento, false para produção)
DJANGO_DEBUG=true

# Hosts permitidos (separados por vírgula)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ===== POSTGRESQL =====
# Mode SSL: require, prefer, disable (padrão: require para produção)
POSTGRES_SSLMODE=require

# ===== API =====
# Tamanho padrão de página (padrão: 25)
API_PAGE_SIZE=25

# ===== LOGGING =====
# Nível de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL (padrão: INFO)
LOG_LEVEL=INFO

# ===== SEGURANÇA (PRODUÇÃO) =====
# Habilitar HTTPS e headers de segurança
# Não alterar em desenvolvimento
SECURE_HSTS_SECONDS=31536000
SECURE_SSL_REDIRECT=true

# ===== OBSERVABILIDADE (OPCIONAL) =====
# Sentry DSN para error tracking
# SENTRY_DSN=https://...@sentry.io/...

# Environment: development, staging, production
ENVIRONMENT=development
